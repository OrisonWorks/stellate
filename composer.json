{
  "name": "sendamaphp/stellate",
  "description": "Stellate - A terminal-based space maze escape game built with Sendama",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "SendamaPHP Team",
      "email": "hello@sendama.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "sendamaphp/engine": "^0.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "start": "php index.php",
    "sendama": "sendama"
  }
}
